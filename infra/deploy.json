{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "8962573537562658646"
    }
  },
  "parameters": {
    "resourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "Resource group that will contain all application resources."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "centralus",
      "metadata": {
        "description": "Azure region for the resource group."
      }
    },
    "appName": {
      "type": "string",
      "metadata": {
        "description": "Short, lowercase application name used in Azure resource names. Use letters, numbers, and hyphens."
      }
    },
    "staticWebAppLocation": {
      "type": "string",
      "defaultValue": "centralus",
      "metadata": {
        "description": "Azure Static Web Apps region. Static Web Apps supports a smaller region set than normal Azure resources."
      }
    },
    "entraClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "The Microsoft Entra Client ID for the production environment."
      }
    },
    "entraTenantId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "The Microsoft Entra Tenant ID for the production environment."
      }
    },
    "allowedEmail": {
      "type": "string",
      "defaultValue": "steveborgra@gmail.com",
      "metadata": {
        "description": "The primary user email allowed to access this workspace."
      }
    },
    "sessionSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "The secure secret used to sign session cookies. Should be at least 32 characters."
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "production",
      "metadata": {
        "description": "The application environment setting (e.g. production, development)."
      }
    }
  },
  "variables": {
    "tags": {
      "app": "[toLower(parameters('appName'))]",
      "managedBy": "bicep",
      "workload": "web-ui"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-03-01",
      "name": "[parameters('resourceGroupName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]"
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "app-resources",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "appName": {
            "value": "[parameters('appName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "staticWebAppLocation": {
            "value": "[parameters('staticWebAppLocation')]"
          },
          "entraClientId": {
            "value": "[parameters('entraClientId')]"
          },
          "entraTenantId": {
            "value": "[parameters('entraTenantId')]"
          },
          "allowedEmail": {
            "value": "[parameters('allowedEmail')]"
          },
          "sessionSecret": {
            "value": "[parameters('sessionSecret')]"
          },
          "environment": {
            "value": "[parameters('environment')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "1635164558853158848"
            }
          },
          "parameters": {
            "appName": {
              "type": "string",
              "metadata": {
                "description": "Short, lowercase application name used in Azure resource names. Use letters, numbers, and hyphens."
              }
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]",
              "metadata": {
                "description": "Azure region for regional resources."
              }
            },
            "staticWebAppLocation": {
              "type": "string",
              "defaultValue": "centralus",
              "metadata": {
                "description": "Azure Static Web Apps region. Static Web Apps supports a smaller region set than normal Azure resources."
              }
            },
            "containerImage": {
              "type": "string",
              "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
              "metadata": {
                "description": "Container image for the Python API. Use a placeholder until the API image exists."
              }
            },
            "apiTargetPort": {
              "type": "int",
              "defaultValue": 8000,
              "metadata": {
                "description": "External port exposed by the API container."
              }
            },
            "apiMaxReplicas": {
              "type": "int",
              "defaultValue": 1,
              "minValue": 1,
              "metadata": {
                "description": "Maximum API replicas. Keep this low for personal-scale cost control."
              }
            },
            "tableName": {
              "type": "string",
              "defaultValue": "finance",
              "metadata": {
                "description": "Cosmos DB Table name for application data."
              }
            },
            "tableThroughput": {
              "type": "int",
              "defaultValue": 400,
              "minValue": 400,
              "maxValue": 1000,
              "metadata": {
                "description": "Provisioned throughput for the Cosmos DB Table API table. Keep <= 1000 RU/s to stay inside the free-tier allowance."
              }
            },
            "enableBlobStorage": {
              "type": "bool",
              "defaultValue": false,
              "metadata": {
                "description": "Create a low-cost blob storage account for optional file persistence."
              }
            },
            "entraClientId": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "The Microsoft Entra Client ID for the production environment."
              }
            },
            "entraTenantId": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "The Microsoft Entra Tenant ID for the production environment."
              }
            },
            "allowedEmail": {
              "type": "string",
              "defaultValue": "steveborgra@gmail.com",
              "metadata": {
                "description": "The primary user email allowed to access this workspace."
              }
            },
            "sessionSecret": {
              "type": "securestring",
              "defaultValue": "",
              "metadata": {
                "description": "The secure secret used to sign session cookies. Should be at least 32 characters."
              }
            },
            "environment": {
              "type": "string",
              "defaultValue": "production",
              "metadata": {
                "description": "The application environment setting (e.g. production, development)."
              }
            }
          },
          "variables": {
            "normalizedAppName": "[toLower(parameters('appName'))]",
            "compactAppName": "[take(replace(variables('normalizedAppName'), '-', ''), 8)]",
            "suffix": "[uniqueString(resourceGroup().id, variables('normalizedAppName'))]",
            "tags": {
              "app": "[variables('normalizedAppName')]",
              "managedBy": "bicep",
              "costProfile": "personal-scale"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Web/staticSites",
              "apiVersion": "2023-12-01",
              "name": "[format('stapp-{0}-{1}', variables('compactAppName'), variables('suffix'))]",
              "location": "[parameters('staticWebAppLocation')]",
              "tags": "[variables('tags')]",
              "sku": {
                "name": "Free",
                "tier": "Free"
              },
              "properties": {
                "allowConfigFileUpdates": true
              }
            },
            {
              "type": "Microsoft.DocumentDB/databaseAccounts",
              "apiVersion": "2024-05-15",
              "name": "[format('cosmos-{0}-{1}', variables('compactAppName'), variables('suffix'))]",
              "location": "[parameters('location')]",
              "tags": "[variables('tags')]",
              "kind": "GlobalDocumentDB",
              "properties": {
                "databaseAccountOfferType": "Standard",
                "enableFreeTier": true,
                "locations": [
                  {
                    "locationName": "[parameters('location')]",
                    "failoverPriority": 0,
                    "isZoneRedundant": false
                  }
                ],
                "capabilities": [
                  {
                    "name": "EnableTable"
                  }
                ],
                "consistencyPolicy": {
                  "defaultConsistencyLevel": "Session"
                }
              }
            },
            {
              "type": "Microsoft.DocumentDB/databaseAccounts/tables",
              "apiVersion": "2024-05-15",
              "name": "[format('{0}/{1}', format('cosmos-{0}-{1}', variables('compactAppName'), variables('suffix')), parameters('tableName'))]",
              "properties": {
                "resource": {
                  "id": "[parameters('tableName')]"
                },
                "options": {
                  "throughput": "[parameters('tableThroughput')]"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}-{1}', variables('compactAppName'), variables('suffix')))]"
              ]
            },
            {
              "type": "Microsoft.ContainerRegistry/registries",
              "apiVersion": "2023-07-01",
              "name": "[format('acr{0}{1}', variables('compactAppName'), variables('suffix'))]",
              "location": "[parameters('location')]",
              "tags": "[variables('tags')]",
              "sku": {
                "name": "Basic"
              },
              "properties": {
                "adminUserEnabled": false
              }
            },
            {
              "type": "Microsoft.App/managedEnvironments",
              "apiVersion": "2024-03-01",
              "name": "[format('cae-{0}-{1}', variables('compactAppName'), variables('suffix'))]",
              "location": "[parameters('location')]",
              "tags": "[variables('tags')]",
              "properties": {}
            },
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[format('ca-{0}-api-{1}', variables('compactAppName'), variables('suffix'))]",
              "location": "[parameters('location')]",
              "tags": "[variables('tags')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}-{1}', variables('compactAppName'), variables('suffix')))]",
                "configuration": {
                  "activeRevisionsMode": "Single",
                  "ingress": {
                    "external": true,
                    "targetPort": "[parameters('apiTargetPort')]",
                    "transport": "auto",
                    "allowInsecure": false
                  },
                  "registries": [
                    {
                      "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', format('acr{0}{1}', variables('compactAppName'), variables('suffix'))), '2023-07-01').loginServer]",
                      "identity": "system"
                    }
                  ],
                  "secrets": [
                    {
                      "name": "cosmos-connection-string",
                      "value": "[listConnectionStrings(resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}-{1}', variables('compactAppName'), variables('suffix'))), '2024-05-15').connectionStrings[0].connectionString]"
                    },
                    {
                      "name": "session-secret",
                      "value": "[if(empty(parameters('sessionSecret')), 'local-dev-session-secret-change-me-longer-32-chars', parameters('sessionSecret'))]"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "api",
                      "image": "[parameters('containerImage')]",
                      "env": [
                        {
                          "name": "FINANCE_COMPANION_COSMOS_TABLE_CONNECTION_STRING",
                          "secretRef": "cosmos-connection-string"
                        },
                        {
                          "name": "FINANCE_COMPANION_COSMOS_TABLE_NAME",
                          "value": "[parameters('tableName')]"
                        },
                        {
                          "name": "FINANCE_COMPANION_SESSION_SECRET",
                          "secretRef": "session-secret"
                        },
                        {
                          "name": "FINANCE_COMPANION_ENVIRONMENT",
                          "value": "[parameters('environment')]"
                        },
                        {
                          "name": "FINANCE_COMPANION_ALLOWED_EMAIL",
                          "value": "[parameters('allowedEmail')]"
                        },
                        {
                          "name": "FINANCE_COMPANION_ENTRA_CLIENT_ID",
                          "value": "[parameters('entraClientId')]"
                        },
                        {
                          "name": "FINANCE_COMPANION_ENTRA_TENANT_ID",
                          "value": "[parameters('entraTenantId')]"
                        },
                        {
                          "name": "FINANCE_COMPANION_CORS_ORIGINS",
                          "value": "[format('[\"http://localhost:5173\", \"https://{0}\"]', reference(resourceId('Microsoft.Web/staticSites', format('stapp-{0}-{1}', variables('compactAppName'), variables('suffix'))), '2023-12-01').defaultHostname)]"
                        }
                      ],
                      "resources": {
                        "cpu": "[json('0.25')]",
                        "memory": "0.5Gi"
                      }
                    }
                  ],
                  "scale": {
                    "minReplicas": 0,
                    "maxReplicas": "[parameters('apiMaxReplicas')]",
                    "rules": [
                      {
                        "name": "http",
                        "http": {
                          "metadata": {
                            "concurrentRequests": "25"
                          }
                        }
                      }
                    ]
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.ContainerRegistry/registries', format('acr{0}{1}', variables('compactAppName'), variables('suffix')))]",
                "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}-{1}', variables('compactAppName'), variables('suffix')))]",
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', format('cosmos-{0}-{1}', variables('compactAppName'), variables('suffix')))]",
                "[resourceId('Microsoft.Web/staticSites', format('stapp-{0}-{1}', variables('compactAppName'), variables('suffix')))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', format('acr{0}{1}', variables('compactAppName'), variables('suffix')))]",
              "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', format('acr{0}{1}', variables('compactAppName'), variables('suffix'))), resourceId('Microsoft.App/containerApps', format('ca-{0}-api-{1}', variables('compactAppName'), variables('suffix'))), 'AcrPull')]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', format('ca-{0}-api-{1}', variables('compactAppName'), variables('suffix'))), '2024-03-01', 'full').identity.principalId]",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ContainerRegistry/registries', format('acr{0}{1}', variables('compactAppName'), variables('suffix')))]",
                "[resourceId('Microsoft.App/containerApps', format('ca-{0}-api-{1}', variables('compactAppName'), variables('suffix')))]"
              ]
            },
            {
              "condition": "[parameters('enableBlobStorage')]",
              "type": "Microsoft.Storage/storageAccounts",
              "apiVersion": "2023-05-01",
              "name": "[format('st{0}{1}', variables('compactAppName'), variables('suffix'))]",
              "location": "[parameters('location')]",
              "tags": "[variables('tags')]",
              "sku": {
                "name": "Standard_LRS"
              },
              "kind": "StorageV2",
              "properties": {
                "accessTier": "Hot",
                "allowBlobPublicAccess": false,
                "minimumTlsVersion": "TLS1_2",
                "supportsHttpsTrafficOnly": true
              }
            }
          ],
          "outputs": {
            "staticWebAppName": {
              "type": "string",
              "value": "[format('stapp-{0}-{1}', variables('compactAppName'), variables('suffix'))]"
            },
            "staticWebAppDefaultHostName": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Web/staticSites', format('stapp-{0}-{1}', variables('compactAppName'), variables('suffix'))), '2023-12-01').defaultHostname]"
            },
            "containerAppName": {
              "type": "string",
              "value": "[format('ca-{0}-api-{1}', variables('compactAppName'), variables('suffix'))]"
            },
            "containerAppUrl": {
              "type": "string",
              "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('ca-{0}-api-{1}', variables('compactAppName'), variables('suffix'))), '2024-03-01').configuration.ingress.fqdn)]"
            },
            "containerEnvironmentName": {
              "type": "string",
              "value": "[format('cae-{0}-{1}', variables('compactAppName'), variables('suffix'))]"
            },
            "cosmosAccountName": {
              "type": "string",
              "value": "[format('cosmos-{0}-{1}', variables('compactAppName'), variables('suffix'))]"
            },
            "cosmosTableEndpoint": {
              "type": "string",
              "value": "[format('https://{0}.table.cosmos.azure.com:443/', format('cosmos-{0}-{1}', variables('compactAppName'), variables('suffix')))]"
            },
            "cosmosTableName": {
              "type": "string",
              "value": "[parameters('tableName')]"
            },
            "storageAccountName": {
              "type": "string",
              "value": "[if(parameters('enableBlobStorage'), format('st{0}{1}', variables('compactAppName'), variables('suffix')), '')]"
            },
            "acrLoginServer": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', format('acr{0}{1}', variables('compactAppName'), variables('suffix'))), '2023-07-01').loginServer]"
            },
            "acrName": {
              "type": "string",
              "value": "[format('acr{0}{1}', variables('compactAppName'), variables('suffix'))]"
            }
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[parameters('resourceGroupName')]"
    },
    "staticWebAppName": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'app-resources'), '2025-04-01').outputs.staticWebAppName.value]"
    },
    "staticWebAppDefaultHostName": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'app-resources'), '2025-04-01').outputs.staticWebAppDefaultHostName.value]"
    },
    "containerAppName": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'app-resources'), '2025-04-01').outputs.containerAppName.value]"
    },
    "containerAppUrl": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'app-resources'), '2025-04-01').outputs.containerAppUrl.value]"
    },
    "cosmosAccountName": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'app-resources'), '2025-04-01').outputs.cosmosAccountName.value]"
    },
    "cosmosTableName": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'app-resources'), '2025-04-01').outputs.cosmosTableName.value]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'app-resources'), '2025-04-01').outputs.acrLoginServer.value]"
    },
    "acrName": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'app-resources'), '2025-04-01').outputs.acrName.value]"
    }
  }
}